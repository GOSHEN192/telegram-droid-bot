# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram user IDs (comma-separated)
ALLOWED_USERS=your_user_id_here

# Droid CLI model
DROID_MODEL=custom:minimax-m2.7

# Droid CLI path
DROID_PATH=/usr/local/bin/droid

# Default working directory for private chats
DROID_CWD=/home/user

# Droid execution timeout (ms)
DROID_TIMEOUT=120000

# Custom model API keys (as needed)
# MINIMAX_API_KEY=your_minimax_api_key_here
# ZAI_API_KEY=your_zai_api_key_here
# XFYUN_API_KEY=your_xfyun_api_key_here
